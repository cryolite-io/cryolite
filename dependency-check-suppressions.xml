<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- False positive: iceberg-parquet 1.10.1 is NOT Apache Parquet 1.10.1.
         The CPE cpe:2.3:a:apache:parquet:1.10.1 incorrectly matches the Iceberg module
         version against the Apache Parquet project. Our actual Parquet version is 1.16.0. -->
    <suppress>
        <notes><![CDATA[
        CPE mismatch: iceberg-parquet version != Apache Parquet version.
        iceberg-parquet is Iceberg's Parquet integration module, not Apache Parquet itself.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.iceberg/iceberg-parquet@.*$</packageUrl>
        <cpe>cpe:/a:apache:parquet</cpe>
    </suppress>

    <!-- False positive: parquet-avro 1.16.0 is NOT Apache Avro.
         CVE-2023-37475 is an Apache Avro vulnerability, but the scanner incorrectly
         matches parquet-avro (Parquet's Avro integration module) against the Avro project. -->
    <suppress>
        <notes><![CDATA[
        CPE mismatch: parquet-avro is Parquet's Avro integration, not Apache Avro itself.
        CVE-2023-37475 affects Apache Avro, not the parquet-avro module.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.parquet/parquet-avro@.*$</packageUrl>
        <cpe>cpe:/a:avro_project:avro</cpe>
    </suppress>

    <!-- False positive: hive-storage-api POM embedded in orc-core jar.
         orc-core is a transitive dependency of hadoop-common. We do not use Apache Hive.
         The CVEs (CVE-2021-34538 etc.) affect Hive Server, not the storage API used by ORC. -->
    <suppress>
        <notes><![CDATA[
        Transitive dependency: hive-storage-api is embedded in orc-core.
        We do not use Hive; these CVEs affect Hive Server, not the storage API.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.hive/hive-storage-api@.*$</packageUrl>
        <cpe>cpe:/a:apache:hive</cpe>
    </suppress>

    <!-- Transitive CVE from Apache Avro 1.12.0 (via parquet-avro).
         CVE-2025-33042 (CVSS 7.3) is in the latest Avro version (1.12.0).
         Awaiting upstream fix from Apache Avro project.
         Impact: Low for our use case (Parquet reader only, no Avro schema evolution). -->
    <suppress>
        <notes><![CDATA[
        Transitive dependency: avro-1.12.0 is required by parquet-avro (Parquet 1.16.0).
        CVE-2025-33042 is in the latest Avro version; awaiting upstream fix.
        We use Avro only for Parquet reading, not for schema evolution or RPC.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.avro/avro@1\.12\.0$</packageUrl>
        <cve>CVE-2025-33042</cve>
    </suppress>

    <!-- Transitive CVEs from Eclipse Jetty 9.4.57 (via hadoop-mapreduce-client-core).
         CVE-2025-5115 (CVSS 7.7) affects websocket-client and websocket-common.
         Jetty 9.4.57 is the latest 9.4.x version; awaiting upstream fix.
         Impact: Low for our use case (Hadoop FileSystem only, no WebSocket usage). -->
    <suppress>
        <notes><![CDATA[
        Transitive dependency: Jetty 9.4.57 is required by hadoop-mapreduce-client-core (Hadoop 3.4.2).
        CVE-2025-5115 affects websocket-client and websocket-common in Jetty 9.4.57.
        Jetty 9.4.57 is the latest 9.4.x version; awaiting upstream fix.
        We use Hadoop only for FileSystem access, not WebSocket functionality.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.eclipse\.jetty\.websocket/(websocket-client|websocket-common)@9\.4\.57\.v20241219$</packageUrl>
        <cve>CVE-2025-5115</cve>
    </suppress>

    <!-- False positive: CVE-2026-25087 is a Use After Free in Apache Arrow C++ (IPC file reading).
         The scanner matches cpe:2.3:a:apache:arrow:18.3.0 against the Java arrow-memory-core JAR,
         but this CVE only affects the native C++ library, not the Java memory allocator.
         We use Arrow Java (arrow-vector + arrow-memory-unsafe) for in-process vectorized execution. -->
    <suppress>
        <notes><![CDATA[
        CVE-2026-25087 affects Apache Arrow C++ (IPC file reading, use-after-free).
        arrow-memory-core is a Java library; the C++ vulnerability does not apply.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.arrow/arrow-.*@.*$</packageUrl>
        <cve>CVE-2026-25087</cve>
    </suppress>

</suppressions>

